# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/quorum
# Production example (TLS): mongodb+srv://user:pass@cluster.mongodb.net/quorum
# For trusted private networks only (production): ALLOW_INSECURE_MONGODB_TRANSPORT=true

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Authentication
# JWT_SECRET is REQUIRED on startup — the server will refuse to start without it.
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
JWT_ISSUER=quorum-api
JWT_AUDIENCE=quorum-client
COOKIE_SAME_SITE=lax

# Reverse proxy hops in front of the application.
# Set to 1 if behind nginx/ALB/Cloudflare, 0 or omit if running exposed directly.
# Incorrect values allow attackers to spoof X-Forwarded-For and bypass rate limits.
TRUST_PROXY=0

# LLM API Keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=your-google-api-key

# Evaluation Settings
EVALUATION_TIMEOUT=30000
OPENAI_MAX_CONCURRENCY=2
ANTHROPIC_MAX_CONCURRENCY=2
GEMINI_MAX_CONCURRENCY=2
PROVIDER_MAX_RETRIES=3
PROVIDER_RETRY_BASE_DELAY_MS=500
PROVIDER_RETRY_MAX_DELAY_MS=10000
PROVIDER_RETRY_JITTER_MS=250

# Adaptive Orchestration
ADAPTIVE_MODE=true
RISK_HIGH_THRESHOLD=0.8
RISK_LOW_THRESHOLD=0.4

# Observability
LOG_PERSIST=false
APP_LOG_TTL_DAYS=30
AUDIT_TTL_DAYS=180

# BYOAK — User API Key Encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_ENCRYPTION_SECRET=your-64-char-hex-string

# Email (Resend) — required for password reset and email verification
# Get your API key at https://resend.com
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Firebase Admin SDK — server-side only, never expose to the client
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Web SDK — public client-side config (safe to expose)
# For Docker deployments: add these to a root-level .env (same dir as docker-compose.yml)
# so docker-compose passes them as frontend build args (baked into the Vite bundle).
# For local dev: these live in frontend/.env instead.
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
