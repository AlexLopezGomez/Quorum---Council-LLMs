# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/quorum

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Authentication
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# LLM API Keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=your-google-api-key

# Evaluation Settings
EVALUATION_TIMEOUT=30000
OPENAI_MAX_CONCURRENCY=2
ANTHROPIC_MAX_CONCURRENCY=2
GEMINI_MAX_CONCURRENCY=2
PROVIDER_MAX_RETRIES=3
PROVIDER_RETRY_BASE_DELAY_MS=500
PROVIDER_RETRY_MAX_DELAY_MS=10000
PROVIDER_RETRY_JITTER_MS=250

# Adaptive Orchestration
ADAPTIVE_MODE=true
RISK_HIGH_THRESHOLD=0.8
RISK_LOW_THRESHOLD=0.4

# Observability
LOG_PERSIST=false
APP_LOG_TTL_DAYS=30
AUDIT_TTL_DAYS=180
